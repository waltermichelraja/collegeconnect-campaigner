{
  "name":"campaigner",
  "version":"1.0.0",
  "description":"WhatsApp Campaign Management Desktop App",
  "author":"Walter Michel Raja",

  "main":"electron/main.cjs",
  "homepage":"./",

  "scripts":{
    "dev":"concurrently \"npm run vite\" \"npm run electron\"",
    "vite":"vite",
    "electron":"wait-on http://localhost:5173 && electron .",
    "build":"vite build",
    "dist":"electron-builder",
    "dist:win":"electron-builder --win",
    "dist:linux":"electron-builder --linux"
  },

  "dependencies":{
    "react":"^18.2.0",
    "react-dom":"^18.2.0"
  },

  "devDependencies":{
    "@vitejs/plugin-react":"^4.2.0",
    "vite":"^5.2.0",
    "electron":"^28.3.0",
    "electron-builder":"^25.1.8",
    "concurrently":"^8.2.2",
    "wait-on":"^7.2.0"
  },

  "build":{
    "appId":"com.campaigner.app",
    "productName":"WACampaigner",

    "files":[
      "dist/**/*",
      "electron/**/*"
    ],

    "asar":true,

    "extraMetadata":{
      "main":"electron/main.cjs"
    },

    "directories":{
      "buildResources":"build"
    },

    "linux":{
      "target":"AppImage",
      "category":"Utility"
    },

    "win":{
      "target":"nsis"
    },

    "nsis":{
      "oneClick":false,
      "allowToChangeInstallationDirectory":true
    }
  }
}